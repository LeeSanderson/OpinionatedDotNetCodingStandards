<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
	<metadata>
		<id>Opinionated.DotNet.CodingStandards</id>
		<version>$version$</version>
		<authors>Lee Sanderson</authors>
		<owners>Lee Sanderson</owners>
		<developmentDependency>true</developmentDependency>
		<license type="expression">MIT</license>
		<readme>README.md</readme>
		<projectUrl>https://github.com/LeeSanderson/OpinionatedDotNetCodingStandards</projectUrl>
		<description>Strongly opinionated coding standards recommendations for .NET.</description>
		<releaseNotes>https://github.com/LeeSanderson/OpinionatedDotNetCodingStandards/blob/main/CHANGELOG.md</releaseNotes>
		<tags>analyzers code-style editorconfig roslyn dotnet csharp</tags>
		<icon>icon.png</icon>
		<repository type="git" url="$RepositoryUrl$" commit="$RepositoryCommit$" branch="$RepositoryBranch$" />
		<dependencies>
			<dependency id="Meziantou.Analyzer" version="3.0.123" />
			<dependency id="Microsoft.CodeAnalysis.BannedApiAnalyzers" version="5.6.0" />
			<dependency id="Microsoft.CodeAnalysis.NetAnalyzers" version="10.0.302" />
			<dependency id="SonarAnalyzer.CSharp" version="10.29.0.143774" />
			<dependency id="StyleCop.Analyzers" version="1.2.0-beta.556" />
		</dependencies>
	</metadata>
	<files>
		<file src="pkgsrc\**" target="" />
	</files>
</package>